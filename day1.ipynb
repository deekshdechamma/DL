   "source": [
    "def perceptron(x1,x2,w1,w2,b):\n",
    "    g=x1*w1+x2*w2+b\n",
    "    if g>0:\n",
    "        return 1\n",
    "    else:\n",
    "        return 0\n",
    "    Z-1/1+np.exp(-g)\n",
    "    if Z>0:\n",
    "        return 1\n",
    "    else:\n",
    "        return 0"
